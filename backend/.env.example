# Environment variables for Stall Capture Backend
# Copy this file to .env and fill in the values

# Django
SECRET_KEY=django-insecure-change-me-in-production-stall-capture-2026
DEBUG=True
ALLOWED_HOSTS=*

# CORS — allow all in dev, restrict in production
CORS_ALLOW_ALL_ORIGINS=True

# Encryption key for Google tokens (must be 32 bytes base64)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=EHlwDhY05D8tg-DvFGDxUaDIOwzGhdnsDgF7B9v49EY=

# Google OAuth Credentials
# Get these from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
